{
  "roots": ["./workspace"],
  "mcpServers": {
    "desktop-commander": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@wonderwhy-er/desktop-commander@latest"],
      "env": {}
    },
    "playwright": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  }
}
